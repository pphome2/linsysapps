#!/bin/bash
# qbackup_tar - Különbözeti mentés (Dátummal az elején, kizárásokkal)

if [ -f "./qconfig" ]; then source "./qconfig"; else exit 1; fi

DATE=$(date +%F)
echo "=== KÜLÖNBÖZETI MENTÉS INDÍTÁSA ==="

# Kizárások kapcsolóinak összeállítása
TAR_EXCLUDES=()
for exc in "${EXCLUDES[@]}"; do
    TAR_EXCLUDES+=("--exclude=$exc")
done

# 1. Rendszer különbözeti mentés
for dir in "${BACKUP_SYSTEM[@]}"; do
    if [ -d "$dir" ]; then
        name=$(basename "$dir")

        if [ -f "${SNAP_DIR}/system_${name}.snap" ]; then
            echo "Különbözeti mentés: ${DATE}_diff_system_${name}"
            cp "${SNAP_DIR}/system_${name}.snap" "${SNAP_DIR}/system_${name}_tmp.snap"

            # A fájlnév most a $DATE változóval kezdődik!
            tar "${TAR_EXCLUDES[@]}" -czg "${SNAP_DIR}/system_${name}_tmp.snap" -f "${BACKUP_DEST}/${DATE}_diff_system_${name}.tar.gz" "$dir"

            rm -f "${SNAP_DIR}/system_${name}_tmp.snap"
        else
            echo "Hiba: Nem található teljes mentés a következőhöz: system_${name}."
        fi
    fi
done

# 2. Felhasználók különbözeti mentése
for user_dir in /home/*; do
    if [ -d "$user_dir" ]; then
        user_name=$(basename "$user_dir")
        for sub_dir in "${BACKUP_HOME_SUBDIRS[@]}"; do
            full_path="${user_dir}/${sub_dir}"
            if [ -d "$full_path" ]; then
                snap_file="${SNAP_DIR}/home_${user_name}_${sub_dir}.snap"

                if [ -f "$snap_file" ]; then
                    echo "Különbözeti mentés: ${DATE}_diff_home_${user_name}_${sub_dir}"
                    cp "$snap_file" "${snap_file}_tmp"

                    # A fájlnév most a $DATE változóval kezdődik!
                    tar "${TAR_EXCLUDES[@]}" -czg "${snap_file}_tmp" -f "${BACKUP_DEST}/${DATE}_diff_home_${user_name}_${sub_dir}.tar.gz" "$full_path"

                    rm -f "${snap_file}_tmp"
                else
                    echo "Hiba: Nincs teljes mentés ehhez: home_${user_name}_${sub_dir}"
                fi
            fi
        done
    fi
done

echo "=== KÜLÖNBÖZETI MENTÉS KÉSZ ==="

#
