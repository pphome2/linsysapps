#!/bin/bash
# qbackup_mariadb - MariaDB/MySQL adatbázisok mentése

if [ -f "./qconfig" ]; then source "./qconfig"; else exit 1; fi

echo "=== MARIADB ADATBÁZISOK MENTÉSE ==="

# 1. Ellenőrizzük, hogy a dump eszköz elérhető-e
if command -v mariadb-dump &> /dev/null; then
    DUMP_CMD="mariadb-dump"
elif command -v mysqldump &> /dev/null; then
    DUMP_CMD="mysqldump"
else
    echo "Hiba: Sem a 'mariadb-dump', sem a 'mysqldump' nem található!"
    exit 1
fi

# 2. Fájlnév meghatározása a paraméter alapján
if [ "$1" == "full" ]; then
    # Teljes mentés esetén fix név
    FINAL_TAR="${BACKUP_DEST}/full_mariadb_all_databases.tar.gz"
    echo "Típus: Teljes mentés (felülírással)"
else
    # Napi mentés esetén dátummal ellátott név
    DATE=$(date +%F)
    FINAL_TAR="${BACKUP_DEST}/${DATE}_diff_mariadb_all_databases.tar.gz"
    echo "Típus: Napi mentés (időzített)"
fi

# Ideiglenes tiszta .sql fájl helye
TMP_SQL="/tmp/all_databases_dump.sql"

# 3. Dump elkészítése
# Az --all-databases mindent ment. A jelszót biztonságosan adjuk át.
echo "Adatbázisok exportálása..."
if [ "$DB_PASS" == "" ]; then
    $DUMP_CMD -u "$DB_USER" --all-databases --single-transaction --quick --lock-tables=false > "$TMP_SQL"
else
    $DUMP_CMD -u "$DB_USER" -p"$DB_PASS" --all-databases --single-transaction --quick --lock-tables=false > "$TMP_SQL"
fi

if [ $? -eq 0 ]; then
    echo "Tömörítés és mentés a célmappába..."
    # Becsomagoljuk a tar.gz-be, a -C /tmp miatt a tar-ban tiszta lesz az útvonal
    tar -czf "$FINAL_TAR" -C /tmp "$(basename "$TMP_SQL")"

    # Kitakarítjuk a felesleges ideiglenes fájlt a /tmp-ből
    rm -f "$TMP_SQL"
    echo "-> Sikeresen elmentve: $(basename "$FINAL_TAR")"
else
    echo "-> [HIBA] Az adatbázis exportálás sikertelen volt!"
    rm -f "$TMP_SQL"
    exit 1
fi

echo "=== MARIADB MENTÉS VÉGE ==="

#
