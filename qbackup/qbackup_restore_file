#!/bin/bash
#
# QBackup
#
# qbackup_restore_file
# Fájl visszaállítása
#

# Konfiguráció betöltése
if [ -f "./qconfig" ]; then source "./qconfig"; else exit 1; fi

# Használat ellenőrzése
if [ -z "$1" ]; then
    echo "Használat: $0 <fájlnév>"
    exit 1
fi

Q_SEARCH_TERM="$1"
Q_FOUND=false

# Visszaállítási mappa létrehozása és abszolút útvonala
mkdir -p "$Q_RESTORE_DEST"
Q_RESTORE_ABS_PATH=$(realpath "$Q_RESTORE_DEST")

# Log
echo ""
echo "=== Visszaállítás indítása: '*${Q_SEARCH_TERM}*'"
echo "$0"
echo ""

# Mentések összegyűjtése biztonságosan, tömbökkel
ALL_BACKUPS=()

# Különbözeti mentések (fordított sorrendben, a legfrissebb az első)
# ha nincs ilyen fáj:
shopt -s nullglob
for f in "${Q_BACKUP_DEST}"/*_diff_*.tar.gz; do
    ALL_BACKUPS+=("$(realpath "$f")")
done
# Fordítot sorrend
if [ ${#ALL_BACKUPS[@]} -gt 0 ]; then
    # tömb megfordítása
    eval 'ALL_BACKUPS=('$(printf '"%s" ' "${ALL_BACKUPS[@]}" | tac)')'
fi

# Teljes mentések hozzáadása a végére
for f in "${Q_BACKUP_DEST}"/full_*.tar.gz; do
    ALL_BACKUPS+=("$(realpath "$f")")
done

shopt -u nullglob

# Keresés és kicsomagolás# Keresés és kicsomagolás
for archive in "${ALL_BACKUPS[@]}"; do
    # Keresés: a 'grep -v "/$"' itt is kell, hogy CSAK a konkrét fájlokat gyűjtsük össze.
    # Ha a fájlokat adjuk oda a tar-nak, a tar magától felépíti hozzájuk a teljes mappautat!
    Q_MATCHING_FILES=$(tar -tzf "$archive" 2>/dev/null | grep -i "$Q_SEARCH_TERM" | grep -v "/$")

    if [ -n "$Q_MATCHING_FILES" ]; then
        echo "Találat ebben a mentésben: $(basename "$archive")"

        while read -r Q_FULL_PATH; do
            [ -z "$Q_FULL_PATH" ] && continue
            # Eltávolítás: / vagy ./
            #Q_REL_PATH=$(echo "$Q_FULL_PATH" | sed -E 's/^\.\///; s/^\///')
            echo "Kicsomagolás - ${Q_FULL_PATH}"
            # Célmappában kicsomagolás
            ( cd "$Q_RESTORE_ABS_PATH" && tar -xzf "$archive" "$Q_FULL_PATH" --overwrite 2>/dev/null )
        done <<< "$Q_MATCHING_FILES"
        Q_FOUND=true
        break # Megvan a legfrissebb verzió, leállhatunk
    fi
done

if [ "$Q_FOUND" = true ]; then
    echo "=== A visszaállítás megtörtént ide: '$Q_RESTORE_ABS_PATH'"
else
    echo "'${Q_SEARCH_TERM}': nincs találat a mentésekben."
fi

echo ""

#

