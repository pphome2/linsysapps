#!/bin/bash
# qbackup_restore_from_file - Helyreállítás egy megadott mentési fájlból kiindulva

if [ -f "./qconfig" ]; then source "./qconfig"; else exit 1; fi

# Paraméterek ellenőrzése
if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Hiba: Hiányzó paraméterek!"
    echo "Használat: $0 <mentés_fájl_neve.tar.gz> <keresett_fájlnév_vagy_töredék>"
    echo "Példa: $0 2026-06-02_diff_home_bela_Dokumentumok.tar.gz szakdoga.txt"
    exit 1
fi

TARGET_ARCHIVE="$1"
SEARCH_TERM="$2"

# Ellenőrizzük, hogy a megadott mentés létezik-e
if [ ! -f "${BACKUP_DEST}/${TARGET_ARCHIVE}" ] && [ ! -f "$TARGET_ARCHIVE" ]; then
    echo "Hiba: A megadott mentési fájl nem található: $TARGET_ARCHIVE"
    exit 1
fi

# Ha csak a fájlnevet adta meg a user, kiegészítjük a backup mappával
if [ -f "${BACKUP_DEST}/${TARGET_ARCHIVE}" ]; then
    ARCHIVE_PATH="${BACKUP_DEST}/${TARGET_ARCHIVE}"
else
    ARCHIVE_PATH="$TARGET_ARCHIVE"
fi

mkdir -p "$RESTORE_DEST"
echo "=== Helyreállítás indítása a(z) $(basename "$ARCHIVE_PATH") alapján ==="

# 1. Megkeressük a pontos belső útvonalat az adott archívumban
MATCHING_FILES=$(tar -tzf "$ARCHIVE_PATH" 2>/dev/null | grep -i "$SEARCH_TERM")

if [ -z "$MATCHING_FILES" ]; then
    echo "Hiba: A(z) '${SEARCH_TERM}' nem található ebben a mentésben: $(basename "$ARCHIVE_PATH")"
    exit 1
fi

# 2. Logika: Teljes vagy különbözeti mentést kaptunk?
filename=$(basename "$ARCHIVE_PATH")

echo "$MATCHING_FILES" | while read -r FULL_PATH; do
    echo "Talált útvonal: $FULL_PATH"

    if [[ "$filename" == *"_diff_"* ]]; then
        # KÜLÖNBÖZETI MENTÉS ESETÉN: meg kell keresni a hozzá tartozó FULL mentést
        # Példa: 2026-06-02_diff_home_bela_Dokumentumok.tar.gz -> full_home_bela_Dokumentumok.tar.gz

        # Levágjuk a dátumot és a diff tag-et a név elejéről
        base_name=$(echo "$filename" | sed -E 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}_diff_//')
        full_archive_path="${BACKUP_DEST}/full_${base_name}"

        if [ -f "$full_archive_path" ]; then
            echo "  -> 1. Lépés: Alapfájl kicsomagolása a TELJES mentésből ($(basename "$full_archive_path"))..."
            tar -xzf "$full_archive_path" "$FULL_PATH" -C "$RESTORE_DEST" 2>/dev/null

            echo "  -> 2. Lépés: Módosítások alkalmazása a KÜLÖNBÖZETI mentésből ($filename)..."
            tar -xzf "$ARCHIVE_PATH" "$FULL_PATH" -C "$RESTORE_DEST" 2>/dev/null
        else
            echo "  [Figyelem] Nem találtam meg a hozzá tartozó teljes mentést (${full_archive_path})!"
            echo "  Megpróbálom csak a különbözeti fájlból kicsomagolni (ha új fájl volt, sikerülni fog)..."
            tar -xzf "$ARCHIVE_PATH" "$FULL_PATH" -C "$RESTORE_DEST" 2>/dev/null
        fi
    else
        # TELJES MENTÉS ESETÉN: csak simán kicsomagoljuk
        echo "  -> Kicsomagolás a teljes mentésből..."
        tar -xzf "$ARCHIVE_PATH" "$FULL_PATH" -C "$RESTORE_DEST"
    fi
done

echo "=== Helyreállítás kész! Ellenőrizd a '$RESTORE_DEST' mappát. ==="

#
